{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "firebase-debug.log",
      "**/firebase-debug.log",
      "**/*.log",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/lee-jonghun-choi-in-simple",
        "destination": "/lee-jonghun-choi-in/simple/",
        "type": 301
      },
      {
        "source": "/lee-jonghun-choi-in-simple/",
        "destination": "/lee-jonghun-choi-in/simple/",
        "type": 301
      }
    ]
  }
}