{
  "name": "mobile-invitation-app",
  "version": "1.0.3",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android:internal": "eas build --platform android --profile preview",
    "build:android:play": "eas build --platform android --profile production",
    "submit:android:play": "eas submit --platform android --profile production",
    "android:verify:kotlin": "node ../../scripts/verify-expo-managed-android.mjs kotlin",
    "android:verify:debug": "node ../../scripts/verify-expo-managed-android.mjs debug",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.4",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.26",
    "expo-constants": "~55.0.16",
    "expo-file-system": "~55.0.22",
    "expo-image": "~55.0.11",
    "expo-image-manipulator": "~55.0.17",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-modules-core": "~55.0.25",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-web-browser": "~55.0.16",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-purchases": "^10.0.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
