{
  "name": "invitation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean:next && next dev",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "next build",
    "start": "serve out -s -l 3000",
    "preview": "serve out -s -l 3000",
    "lint": "next lint",
    "export": "next build",
    "deploy:firebase": "npm run build && npm run export && firebase deploy"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@types/react-datepicker": "^6.2.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.0.0",
    "next": "15.4.1",
    "react": "19.1.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "serve": "^14.2.6",
    "typescript": "^5"
  }
}
