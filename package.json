{
  "name": "invitation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean:next && next dev",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "validate:theme-extension": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/validate-theme-extension.mts",
    "lint:web": "eslint .",
    "lint:mobile": "npm --prefix apps/mobile run lint",
    "mb:start": "npm --prefix apps/mobile run start",
    "mb:android": "npm --prefix apps/mobile run android",
    "mb:web": "npm --prefix apps/mobile run web",
    "mb:build:android:internal": "npm --prefix apps/mobile run build:android:internal",
    "mb:build:android:play": "npm --prefix apps/mobile run build:android:play",
    "mb:submit:android:play": "npm --prefix apps/mobile run submit:android:play",
    "sync:memory-metadata": "node scripts/sync-memory-page-metadata.mjs",
    "backfill:events": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/backfill-events.mts",
    "delete:legacy-event-collections": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/delete-legacy-event-collections.mts",
    "monitor:event-rollout": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/monitor-event-rollout.mts",
    "typecheck:web": "tsc --noEmit",
    "typecheck:mobile": "npm --prefix apps/mobile run typecheck",
    "typecheck": "npm run typecheck:web && npm run typecheck:mobile",
    "test:readthrough-repositories": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-event-readthrough.mts",
    "test:event-backfill": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-event-backfill-plan.mts",
    "test:api-repository-boundary": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-api-repository-boundary.mts",
    "test:service-repository-boundary": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-service-repository-boundary.mts",
    "test:event-write-paths": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-event-write-paths.mts",
    "test:slug-index": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-event-slug-index.mts",
    "test:write-through-repositories": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/test-event-write-through.mts",
    "qa:event-rollout": "npm run test:api-repository-boundary && npm run test:readthrough-repositories && npm run test:write-through-repositories && npm run test:slug-index && npm run test:event-backfill && npm run typecheck:web && npm run lint:web && npm run typecheck:mobile && npm run lint:mobile",
    "build": "npm run sync:memory-metadata && npm run clean:next && next build",
    "build:memory-metadata-strict": "npm run sync:memory-metadata -- --strict && npm run clean:next && next build",
    "start": "next start",
    "preview": "next start -p 3000",
    "lint": "npm run lint:web && npm run lint:mobile",
    "check": "npm run lint && npm run typecheck",
    "test:smoke": "npm run sync:memory-metadata && npm run clean:next && next build",
    "test": "npm run sync:memory-metadata && npm run clean:next && next build",
    "export": "next build",
    "deploy:firebase": "npm run build:memory-metadata-strict && firebase deploy"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@types/react-datepicker": "^6.2.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.0.0",
    "next": "^15.4.8",
    "react": "^19.1.2",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.1.2",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.4.8",
    "firebase-admin": "^13.7.0",
    "serve": "^14.2.6",
    "typescript": "^5"
  }
}
