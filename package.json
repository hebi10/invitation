{
  "name": "invitation",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean:next && next dev",
    "clean:next": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "mb:start": "npm --prefix apps/mobile run start",
    "mb:android": "npm --prefix apps/mobile run android",
    "mb:web": "npm --prefix apps/mobile run web",
    "sync:memory-metadata": "node scripts/sync-memory-page-metadata.mjs",
    "build": "npm run sync:memory-metadata && npm run clean:next && next build",
    "build:memory-metadata-strict": "npm run sync:memory-metadata -- --strict && npm run clean:next && next build",
    "start": "next start",
    "preview": "next start -p 3000",
    "lint": "eslint .",
    "seed:invitation-pages": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/seed-invitation-pages.mjs analyze",
    "seed:invitation-pages:execute": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/seed-invitation-pages.mjs seed --execute",
    "seed:invitation-pages:validate": "node --experimental-strip-types --loader ./scripts/ts-path-loader.mjs scripts/seed-invitation-pages.mjs validate",
    "export": "next build",
    "deploy:firebase": "npm run build:memory-metadata-strict && firebase deploy"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "@types/react-datepicker": "^6.2.0",
    "date-fns": "^4.1.0",
    "firebase": "^12.0.0",
    "next": "^15.4.8",
    "react": "^19.1.2",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.1.2",
    "swiper": "^12.1.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.4.8",
    "firebase-admin": "^13.7.0",
    "serve": "^14.2.6",
    "typescript": "^5"
  }
}
