rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin-users/$(request.auth.uid)).data.enabled != false;
    }

    function isPublicMemoryPage(data) {
      return data.enabled == true &&
        (data.visibility == 'public' || data.visibility == 'unlisted');
    }

    function isValidCommentCreate() {
      return request.resource.data.keys().hasOnly(['author', 'message', 'pageSlug', 'createdAt']) &&
        request.resource.data.author is string &&
        request.resource.data.author.size() > 0 &&
        request.resource.data.author.size() <= 40 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 1000 &&
        request.resource.data.pageSlug is string &&
        request.resource.data.pageSlug.size() > 0 &&
        request.resource.data.pageSlug.size() <= 120;
    }

    function hasClientAccess(pageSlug, editorTokenHash) {
      return pageSlug is string &&
        editorTokenHash is string &&
        exists(/databases/$(database)/documents/client-access/$(pageSlug)) &&
        get(/databases/$(database)/documents/client-access/$(pageSlug)).data.editorTokenHash == editorTokenHash;
    }

    function isClientCommentDelete() {
      return resource.data.deleted != true &&
        request.resource.data.keys().hasOnly([
          'author',
          'message',
          'pageSlug',
          'createdAt',
          'deleted',
          'deletedAt',
          'deletedBy',
          'editorTokenHash'
        ]) &&
        request.resource.data.author == resource.data.author &&
        request.resource.data.message == resource.data.message &&
        request.resource.data.pageSlug == resource.data.pageSlug &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.deleted == true &&
        request.resource.data.deletedBy == 'client' &&
        hasClientAccess(resource.data.pageSlug, request.resource.data.editorTokenHash);
    }

    function isClientConfigWrite(pageSlug) {
      return request.resource.data.slug == pageSlug &&
        request.resource.data.editorTokenHash is string &&
        hasClientAccess(pageSlug, request.resource.data.editorTokenHash);
    }

    function isClientRegistryWrite(pageSlug) {
      return request.resource.data.pageSlug == pageSlug &&
        request.resource.data.editorTokenHash is string &&
        hasClientAccess(pageSlug, request.resource.data.editorTokenHash);
    }

    match /memory-pages/{pageSlug} {
      allow read: if isPublicMemoryPage(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidCommentCreate();
      allow update: if isAdmin() || isClientCommentDelete();
      allow delete: if isAdmin();
    }

    match /client-passwords/{document=**} {
      allow read, write: if isAdmin();
    }

    match /client-access/{pageSlug} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /invitation-page-configs/{pageSlug} {
      allow read: if true;
      allow create, update: if isAdmin() || isClientConfigWrite(pageSlug);
      allow delete: if isAdmin();
    }

    match /invitation-page-registry/{pageSlug} {
      allow read: if true;
      allow create, update: if isAdmin() || isClientRegistryWrite(pageSlug);
      allow delete: if isAdmin();
    }

    match /admin-users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /display-periods/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
