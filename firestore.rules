rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin-users/$(request.auth.uid)).data.enabled != false;
    }

    function isEventOwnerById(eventId) {
      return isSignedIn() &&
        eventId is string &&
        exists(/databases/$(database)/documents/events/$(eventId)) &&
        get(/databases/$(database)/documents/events/$(eventId)).data.ownerUid == request.auth.uid;
    }

    function isEventOwnerBySlug(slug) {
      let slugIndex = get(/databases/$(database)/documents/eventSlugIndex/$(slug));
      return slug is string &&
        slugIndex.data.eventId is string &&
        isEventOwnerById(slugIndex.data.eventId);
    }

    function canCreateOwnedEvent() {
      return isSignedIn() &&
        request.resource.data.ownerUid is string &&
        request.resource.data.ownerUid == request.auth.uid;
    }

    function canUpdateOwnedEvent(eventId) {
      return isEventOwnerById(eventId) &&
        request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function canWriteOwnedSlugIndex() {
      return isSignedIn() &&
        request.resource.data.eventId is string &&
        isEventOwnerById(request.resource.data.eventId);
    }

    function isPublicMemoryPage(data) {
      return data.enabled == true &&
        (data.visibility == 'public' || data.visibility == 'unlisted');
    }

    function isValidCommentCreate() {
      return request.resource.data.keys().hasOnly(['author', 'message', 'pageSlug', 'createdAt']) &&
        request.resource.data.author is string &&
        request.resource.data.author.size() > 0 &&
        request.resource.data.author.size() <= 40 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 1000 &&
        request.resource.data.pageSlug is string &&
        request.resource.data.pageSlug.size() > 0 &&
        request.resource.data.pageSlug.size() <= 120;
    }

    function canReadPublicGuestbookComment(data) {
      return data.deleted != true &&
        data.status != 'hidden' &&
        data.status != 'pending_delete' &&
        !(
          data.scheduledDeleteAt is timestamp &&
          data.scheduledDeleteAt <= request.time
        );
    }

    function hasEventDisplayPeriodData(data) {
      return (
        data.displayPeriod is map &&
        data.displayPeriod.isActive == true &&
        data.displayPeriod.startDate is timestamp &&
        data.displayPeriod.endDate is timestamp
      ) || (
        !(data.displayPeriod is map) &&
        data.visibility.displayStartAt is timestamp &&
        data.visibility.displayEndAt is timestamp
      );
    }

    function isWithinEventDisplayPeriodData(data) {
      return !hasEventDisplayPeriodData(data) ||
        (
          data.displayPeriod is map &&
          request.time >= data.displayPeriod.startDate &&
          request.time <= data.displayPeriod.endDate
        ) ||
        (
          !(data.displayPeriod is map) &&
          request.time >= data.visibility.displayStartAt &&
          request.time <= data.visibility.displayEndAt
        );
    }

    function canReadPublicEventData(data) {
      return data.visibility.published == true &&
        isWithinEventDisplayPeriodData(data);
    }

    function canReadPublicEvent(eventId) {
      return eventId is string &&
        canReadPublicEventData(
          get(/databases/$(database)/documents/events/$(eventId)).data
        );
    }

    function isValidCommentCreateForEvent(eventId) {
      return isValidCommentCreate() &&
        exists(/databases/$(database)/documents/events/$(eventId)) &&
        request.resource.data.pageSlug ==
          get(/databases/$(database)/documents/events/$(eventId)).data.slug;
    }

    function canReadPublicEventSlugIndex(slug) {
      let slugIndex = get(/databases/$(database)/documents/eventSlugIndex/$(slug));
      return slug is string &&
        (
          slugIndex.data.status == 'active' ||
          slugIndex.data.status == 'redirect'
        ) &&
        slugIndex.data.eventId is string &&
        canReadPublicEvent(slugIndex.data.eventId);
    }

    match /memory-pages/{pageSlug} {
      allow read: if isPublicMemoryPage(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /admin-users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update, delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAdmin() || isEventOwnerById(eventId) || canReadPublicEvent(eventId);
      allow create: if isAdmin() || canCreateOwnedEvent();
      allow update, delete: if isAdmin() || canUpdateOwnedEvent(eventId);

      match /content/{documentId} {
        allow read: if isAdmin() || isEventOwnerById(eventId) || canReadPublicEvent(eventId);
        allow create, update, delete: if isAdmin() || isEventOwnerById(eventId);
      }

      match /comments/{commentId} {
        allow read: if isAdmin() || isEventOwnerById(eventId) || (
          canReadPublicEvent(eventId) &&
          canReadPublicGuestbookComment(resource.data)
        );
        allow create: if false;
        allow update, delete: if isAdmin() || isEventOwnerById(eventId);
      }

      match /linkTokens/{tokenId} {
        allow read, write: if isAdmin() || isEventOwnerById(eventId);
      }

      match /auditLogs/{logId} {
        allow read: if isAdmin() || isEventOwnerById(eventId);
        allow write: if isAdmin();
      }
    }

    match /eventSecrets/{eventId} {
      allow read, write: if isAdmin();
    }

    match /eventSlugIndex/{slug} {
      allow read: if isAdmin() || isEventOwnerBySlug(slug) || canReadPublicEventSlugIndex(slug);
      allow create, update: if isAdmin() || canWriteOwnedSlugIndex();
      allow delete: if isAdmin() || (
        resource.data.eventId is string &&
        isEventOwnerById(resource.data.eventId)
      );
    }

    match /billingFulfillments/{transactionId} {
      allow read, write: if isAdmin();
    }

    match /event-write-through-failures/{failureId} {
      allow read, write: if isAdmin();
    }

    match /event-read-fallback-logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /event-rollout-mismatches/{mismatchId} {
      allow read, write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
