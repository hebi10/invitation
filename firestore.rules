rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admin-users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admin-users/$(request.auth.uid)).data.enabled != false;
    }

    function isPublicMemoryPage(data) {
      return data.enabled == true &&
        (data.visibility == 'public' || data.visibility == 'unlisted');
    }

    function isValidCommentCreate() {
      return request.resource.data.keys().hasOnly(['author', 'message', 'pageSlug', 'createdAt']) &&
        request.resource.data.author is string &&
        request.resource.data.author.size() > 0 &&
        request.resource.data.author.size() <= 40 &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() <= 1000 &&
        request.resource.data.pageSlug is string &&
        request.resource.data.pageSlug.size() > 0 &&
        request.resource.data.pageSlug.size() <= 120;
    }

    function isValidCommentCreateForPage(pageSlug) {
      return isValidCommentCreate() &&
        request.resource.data.pageSlug == pageSlug;
    }

    function hasPublishedInvitationRegistry(pageSlug) {
      return pageSlug is string &&
        exists(/databases/$(database)/documents/invitation-page-registry/$(pageSlug)) &&
        get(/databases/$(database)/documents/invitation-page-registry/$(pageSlug)).data.published == true;
    }

    function hasInvitationDisplayPeriod(pageSlug) {
      return pageSlug is string &&
        exists(/databases/$(database)/documents/display-periods/$(pageSlug)) &&
        get(/databases/$(database)/documents/display-periods/$(pageSlug)).data.isActive == true;
    }

    function isWithinInvitationDisplayPeriod(pageSlug) {
      return !hasInvitationDisplayPeriod(pageSlug) ||
        (
          get(/databases/$(database)/documents/display-periods/$(pageSlug)).data.startDate is timestamp &&
          get(/databases/$(database)/documents/display-periods/$(pageSlug)).data.endDate is timestamp &&
          request.time >= get(/databases/$(database)/documents/display-periods/$(pageSlug)).data.startDate &&
          request.time <= get(/databases/$(database)/documents/display-periods/$(pageSlug)).data.endDate
        );
    }

    function canReadPublicInvitationPage(pageSlug) {
      return hasPublishedInvitationRegistry(pageSlug) &&
        isWithinInvitationDisplayPeriod(pageSlug);
    }

    function isLegacyCommentCollection(collectionId) {
      return collectionId.matches('^comments-.+$');
    }

    match /memory-pages/{pageSlug} {
      allow read: if isPublicMemoryPage(resource.data) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isValidCommentCreate();
      allow update, delete: if isAdmin();
    }

    match /guestbooks/{pageSlug} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isValidCommentCreateForPage(pageSlug);
        allow update, delete: if isAdmin();
      }
    }

    match /{collectionId}/{commentId} {
      allow read: if isLegacyCommentCollection(collectionId);
      allow delete: if isLegacyCommentCollection(collectionId) && isAdmin();
    }

    match /client-passwords/{document=**} {
      allow read, write: if isAdmin();
    }

    match /client-access/{pageSlug} {
      allow read, write: if isAdmin();
    }

    match /invitation-page-configs/{pageSlug} {
      allow read: if isAdmin() || canReadPublicInvitationPage(pageSlug);
      allow create, update, delete: if isAdmin();
    }

    match /invitation-page-registry/{pageSlug} {
      allow read: if isAdmin() || canReadPublicInvitationPage(pageSlug);
      allow create, update, delete: if isAdmin();
    }

    match /admin-users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /display-periods/{pageSlug} {
      allow read: if isAdmin() || canReadPublicInvitationPage(pageSlug);
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
