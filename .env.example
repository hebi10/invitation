# Firebase public configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase usage
NEXT_PUBLIC_USE_FIREBASE=true

# Kakao
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=your_kakao_javascript_key_here
NEXT_PUBLIC_KAKAO_MAP_API_KEY=
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# Expo mobile app
EXPO_PUBLIC_API_BASE=http://localhost:3000
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=

# Firebase Admin / App Hosting server runtime
# Keep these out of NEXT_PUBLIC_* variables.
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
GOOGLE_CLOUD_PROJECT=
GCLOUD_PROJECT=

# Client editor server secrets
CLIENT_EDITOR_SESSION_SECRET=
MOBILE_CLIENT_EDITOR_HIGH_RISK_SECRET=
MOBILE_CLIENT_EDITOR_LINK_TOKEN_SECRET=
MOBILE_DRAFT_CREATION_ENABLED=

# RevenueCat / Google Play Billing server secret
REVENUECAT_SERVER_API_KEY=
MOBILE_BILLING_ALLOW_MOCK=

# Event rollout controls
EVENT_ROLLOUT_WRITE_MODE=event-only
EVENT_ROLLOUT_ENABLE_LEGACY_READ_FALLBACK=
EVENT_ROLLOUT_LEGACY_READ_FALLBACK_UNTIL=

# Build and local tooling
MEMORY_METADATA_SYNC_STRICT=
NEXT_DISABLE_WEBPACK_BUILD_WORKER=
NEXT_PUBLIC_ENABLE_DEV_TOOLS=
ENABLE_DEV_TOOLS=
