rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admin-users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admin-users/$(request.auth.uid)).data.enabled != false;
    }

    match /wedding-images/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /memory-images/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
