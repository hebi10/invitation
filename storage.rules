rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admin-users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admin-users/$(request.auth.uid)).data.enabled != false;
    }

    function isEventOwnerBySlug(pageSlug) {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/eventSlugIndex/$(pageSlug)) &&
        firestore.get(/databases/(default)/documents/eventSlugIndex/$(pageSlug)).data.eventId is string &&
        firestore.exists(
          /databases/(default)/documents/events/$(firestore.get(/databases/(default)/documents/eventSlugIndex/$(pageSlug)).data.eventId)
        ) &&
        firestore.get(
          /databases/(default)/documents/events/$(firestore.get(/databases/(default)/documents/eventSlugIndex/$(pageSlug)).data.eventId)
        ).data.ownerUid == request.auth.uid;
    }

    function isImageWriteRequest() {
      return request.resource != null &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    match /wedding-images/{pageSlug}/{allPaths=**} {
      allow read: if true;
      allow create, update: if (isAdmin() || isEventOwnerBySlug(pageSlug)) && isImageWriteRequest();
      allow delete: if isAdmin() || isEventOwnerBySlug(pageSlug);
    }

    match /memory-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isImageWriteRequest();
      allow delete: if isAdmin();
    }

    match /music/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
