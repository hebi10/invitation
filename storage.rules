rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admin-users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admin-users/$(request.auth.uid)).data.enabled != false;
    }

    function hasClientAccess(pageSlug, editorTokenHash) {
      return editorTokenHash is string &&
        firestore.exists(/databases/(default)/documents/client-access/$(pageSlug)) &&
        firestore.get(/databases/(default)/documents/client-access/$(pageSlug)).data.editorTokenHash == editorTokenHash;
    }

    function isDeleteOperation() {
      return request.resource == null;
    }

    function isValidClientImageWrite(pageSlug) {
      return !isDeleteOperation() &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*') &&
        request.resource.metadata.editorTokenHash is string &&
        hasClientAccess(pageSlug, request.resource.metadata.editorTokenHash);
    }

    function isValidClientImageDelete(pageSlug) {
      return isDeleteOperation() &&
        resource != null &&
        resource.metadata.editorTokenHash is string &&
        hasClientAccess(pageSlug, resource.metadata.editorTokenHash);
    }

    match /wedding-images/{pageSlug}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() || isValidClientImageWrite(pageSlug) || isValidClientImageDelete(pageSlug);
    }

    match /memory-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
